---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
---

<Layout
    pageTitle="Page Not Found - 404"
    description="The page you requested could not be found."
>
    <main
        class="flex flex-col items-center justify-center min-h-[calc(100vh-200px)] text-blacktext dark:text-gray-200 py-8 md:py-16 px-4 text-center font-montserrat"
    >
        <h1
            class="text-9xl font-bold mb-8 tracking-wider bg-clip-text text-transparent bg-gradient-to-r from-mint-500 to-riptide-500 max-sm:text-7xl"
        >
            404
        </h1>

        <h2
            class="text-4xl max-md:text-3xl font-bold mb-6 text-blacktext dark:text-white"
        >
            Page Not Found
        </h2>

        <p
            class="max-w-xl text-xl leading-relaxed mb-10 text-pretty text-blacktext dark:text-gray-200"
        >
            Oh-oh! Gabibbo ate this page.
        </p>

        <a
            href="/"
            class="inline-flex items-center gap-2 px-6 py-3 text-black rounded-xl font-semibold text-lg transition-all duration-300 transform hover:-translate-y-1 hover:shadow-2xl shadow-lg
             bg-gradient-to-r from-mint-500 to-riptide-500 hover:from-mint-600 hover:to-riptide-600 focus:outline-none focus:ring-4 focus:ring-mint-500/50 dark:from-riptide-500 dark:to-mint-500 dark:hover:from-riptide-600 dark:hover:to-mint-600 dark:focus:ring-riptide-500/50"
        >
            <Icon name="arrow-left" class="size-6 mr-2" aria-hidden="true" />
            <span class="tracking-wide">Home</span>
        </a>
    </main>
</Layout>
